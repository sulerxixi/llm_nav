<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="my_robot">
    <xacro:include filename="$(find my_robot_description)/urdf/my_robot/base.urdf.xacro" />
    <!-- 传感器组件 -->
    <xacro:include filename="$(find my_robot_description)/urdf/my_robot/sensor/imu.urdf.xacro" />
    <!-- <xacro:include filename="$(find my_robot_description)/urdf/my_robot/sensor/laser.urdf.xacro" /> -->
    <xacro:include filename="$(find ros2_livox_simulation)/urdf/mid360.xacro" />
    <xacro:include filename="$(find my_robot_description)/urdf/my_robot/sensor/camera.urdf.xacro" />
     <!-- 执行器组件 -->
    <xacro:include filename="$(find my_robot_description)/urdf/my_robot/actuator/wheel.urdf.xacro" />
    <xacro:include filename="$(find my_robot_description)/urdf/my_robot/actuator/caster.urdf.xacro" />

    <xacro:base_xacro length="0.12" radius="0.1" />
    <!-- 传感器 -->
    <xacro:imu_xacro xyz="0 0 0.02" />
    <!-- <xacro:laser_xacro xyz="0 0 0.08" /> -->
    <xacro:mid360 name="livox_mid360" parent="base_link" topic="/livox/lidar">
        <origin xyz="0 0 0.08" rpy="0 0 0"/>
    </xacro:mid360>
    <xacro:camera_xacro xyz="0.10 0 0.075" />
    <!-- 执行器主动轮+从动轮 -->
    <xacro:wheel_xacro wheel_name="left" xyz="0 0.10 -0.06" />
    <xacro:wheel_xacro wheel_name="right" xyz="0 -0.10 -0.06" />
    <xacro:caster_xacro caster_name="front" xyz="0.08 0.0 -0.076" />
    <xacro:caster_xacro caster_name="back" xyz="-0.08 0.0 -0.076" />
    <!-- Gazebo 插件 -->
    <xacro:include filename="$(find my_robot_description)/urdf/my_robot/plugins/gazebo_control_plugin.xacro" />
    <!-- <xacro:gazebo_control_plugin /> -->
    <xacro:include filename="$(find my_robot_description)/urdf/my_robot/my_robot.ros2_control.xacro" />
    <xacro:my_robot_ros2_control />
    <xacro:include filename="$(find my_robot_description)/urdf/my_robot/plugins/gazebo_sensor_plugin.xacro" />
    <xacro:gazebo_sensor_plugin />
</robot>
